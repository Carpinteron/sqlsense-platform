generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["academic", "auth", "challenge", "evaluation"]
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(20)
  users User[]

  @@map("roles")
  @@schema("auth")
}

model User {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String                @unique
  password            String
  role_id             Int?
  createdAt           DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  course_students     CourseStudent[]
  courses             Course[]
  roles               Role?                 @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  challenges          challenges[]
  submissions         submissions[]
  evaluation_attempts evaluation_attempts[]

  @@index([role_id], map: "idx_users_role")
  @@map("users")
  @@schema("auth")
}

model Course {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String          @db.VarChar(100)
  code            String          @unique @db.VarChar(50)
  period          String          @db.VarChar(20)
  groupNumber     String?         @map("group_number") @db.VarChar(10)
  professor_id    String?         @db.Uuid
  createdAt       DateTime?       @default(now()) @map("created_at") @db.Timestamp(6)
  course_students CourseStudent[]
  users           User?           @relation(fields: [professor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  challenges      challenges[]
  evaluations     evaluations[]

  @@index([professor_id], map: "idx_courses_professor")
  @@map("courses")
  @@schema("academic")
}

model CourseStudent {
  course_id  String @db.Uuid
  student_id String @db.Uuid
  courses    Course @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User   @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([course_id, student_id])
  @@index([student_id], map: "idx_course_students_student")
  @@map("course_students")
  @@schema("academic")
}

model challenges {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String
  description           String
  difficulty            difficulty_enum?
  tags                  String[]
  database_engine       String?                 @default("PostgreSQL") @db.VarChar(20)
  time_limit            Int?
  status                status_enum?            @default(draft)
  course_id             String?                 @db.Uuid
  created_by            String?                 @db.Uuid
  schema_sql            String?
  seed_data_sql         String?
  expected_result       Json?
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  courses               Course?                 @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                 User?                   @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  submissions           submissions[]
  evaluation_challenges evaluation_challenges[]

  @@index([course_id], map: "idx_challenges_course")
  @@schema("challenge")
}

model submissions {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id        String?            @db.Uuid
  challenge_id      String?            @db.Uuid
  query             String
  status            submission_status? @default(QUEUED)
  execution_time_ms Int?
  score             Int?
  result            Json?
  feedback          String?
  created_at        DateTime?          @default(now()) @db.Timestamp(6)
  challenges        challenges?        @relation(fields: [challenge_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             User?              @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([challenge_id], map: "idx_submissions_challenge")
  @@index([student_id], map: "idx_submissions_student")
  @@schema("challenge")
}

model evaluation_attempts {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluation_id String?      @db.Uuid
  student_id    String?      @db.Uuid
  started_at    DateTime?    @db.Timestamp(6)
  submitted_at  DateTime?    @db.Timestamp(6)
  score         Int?
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
  evaluations   evaluations? @relation(fields: [evaluation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         User?        @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("evaluation")
}

model evaluation_challenges {
  evaluation_id String      @db.Uuid
  challenge_id  String      @db.Uuid
  challenges    challenges  @relation(fields: [challenge_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  evaluations   evaluations @relation(fields: [evaluation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([evaluation_id, challenge_id])
  @@schema("evaluation")
}

model evaluations {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String                  @db.VarChar(100)
  description           String?
  start_date            DateTime?               @db.Timestamp(6)
  end_date              DateTime?               @db.Timestamp(6)
  duration_minutes      Int?
  max_attempts          Int?
  course_id             String?                 @db.Uuid
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  evaluation_attempts   evaluation_attempts[]
  evaluation_challenges evaluation_challenges[]
  courses               Course?                 @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([course_id], map: "idx_evaluations_course")
  @@schema("evaluation")
}

enum difficulty_enum {
  Easy
  Medium
  Hard

  @@schema("challenge")
}

enum status_enum {
  draft
  published
  archived

  @@schema("challenge")
}

enum submission_status {
  QUEUED
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  SYNTAX_ERROR
  TIME_LIMIT_EXCEEDED
  RUNTIME_ERROR
  OPTIMIZATION_REQUIRED

  @@schema("challenge")
}
